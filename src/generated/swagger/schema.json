  "components": {
    "schemas": {
      "TokenObtainPair": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "writeOnly": true
          },
          "password": {
            "type": "string",
            "writeOnly": true
          },
          "access": {
            "type": "string",
            "readOnly": true
          },
          "refresh": {
            "type": "string",
            "readOnly": true
          }
        },
        "required": [
          "access",
          "password",
          "refresh",
          "username"
        ]
      },
      "TokenRefresh": {
        "type": "object",
        "properties": {
          "access": {
            "type": "string",
            "readOnly": true
          },
          "refresh": {
            "type": "string",
            "writeOnly": true
          }
        },
        "required": [
          "access",
          "refresh"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "username": {
            "type": "string",
            "title": "שם משתמש",
            "description": "שדה חובה. 150 תווים או פחות. אותיות, ספרות ו-@/./+/-/_ בלבד.",
            "pattern": "^[\\w.@+-]+$",
            "maxLength": 150
          },
          "email": {
            "type": "string",
            "format": "email",
            "title": "כתובת דוא\"ל",
            "maxLength": 254,
            "minLength": 1
          },
          "first_name": {
            "type": "string",
            "title": "שם פרטי",
            "maxLength": 150
          },
          "last_name": {
            "type": "string",
            "title": "שם משפחה",
            "maxLength": 150
          }
        },
        "required": [
          "email",
          "id",
          "username"
        ]
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sessionid"
      }
    }
  }
