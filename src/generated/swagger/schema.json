    "/authentication/users/me/": {
      "get": {
        "operationId": "authentication_users_me_retrieve",
        "tags": [
          "authentication"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            },
            "description": ""
          }
        }
